{
  "name": "justified-feed-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:dataset:unsplash": "tsx scripts/gen-unsplash-dataset.ts",
    "gen:dataset:unsplash:cache": "tsx scripts/gen-unsplash-dataset.ts --from-cache"
  },
  "dependencies": {
    "@radix-ui/react-slider": "1.3.6",
    "@tanstack/react-virtual": "3.13.26",
    "blurhash": "2.0.5",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/plugin-transform-runtime": "7.29.7",
    "@babel/runtime": "7.29.7",
    "@eslint/js": "10.0.1",
    "@rolldown/plugin-babel": "0.2.3",
    "@types/babel__core": "7.20.5",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "playwright": "1.60.0",
    "prettier": "3.8.3",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  }
}
